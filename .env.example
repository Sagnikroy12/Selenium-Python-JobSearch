# Browser and scraper settings
HEADLESS=true
BROWSER=chrome
JOB_TITLE_TARGET=Automation Engineer
JOB_LOCATION_TARGET=Hyderabad
RESUME_PDF_PATH=my_resume.pdf

# Output and email behavior
SEND_EMAIL=false
RECIPIENT_EMAIL=recipient@example.com
EMAIL_SUBJECT=Daily ATS Job Match Report

# Multi-user batch mode (Google Forms + Sheets intake)
BATCH_MODE=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Form Responses 1
# Provide either inline JSON or a path to the service-account key file
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS_PATH=

# Generic SMTP settings
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.email@gmail.com
# SMTP_PASSWORD=your-gmail-app-password
# MAIL_FROM=your.email@gmail.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=jobs@example.com
